# Public frontend runtime config
NEXT_PUBLIC_STAGE_MODE=auto
NEXT_PUBLIC_APP_NAME=Stage Me
NEXT_PUBLIC_ENABLE_LOCAL_REPORTS=true
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=true

# Default to internal Next.js API routes.
# These values work immediately in local demo mode.
NEXT_PUBLIC_STAGE_API_BASE_URL=/api
NEXT_PUBLIC_ZHIHU_TOPIC_API_URL=/api/topics/zhihu

# Fill these when Second Me OAuth is ready.
NEXT_PUBLIC_SECOND_ME_AUTH_URL=
NEXT_PUBLIC_SECOND_ME_CLIENT_ID=
NEXT_PUBLIC_SECOND_ME_REDIRECT_URI=http://localhost:3002/api/auth/callback

# Server-only envs for later backend/BFF integration.
SECOND_ME_CLIENT_SECRET=
SECOND_ME_TOKEN_URL=
ZHIHU_TOPIC_API_UPSTREAM=
SESSION_SECRET=
DATABASE_URL=
